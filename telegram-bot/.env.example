# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key（從 https://console.anthropic.com 取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 允許使用此 Bot 的 Telegram Chat ID（逗號分隔，留空表示允許所有人）
# 用 /id 指令查詢您的 Chat ID
ALLOWED_CHAT_IDS=123456789,987654321

# Claude 的系統提示詞（可自訂角色）
SYSTEM_PROMPT=你是一位高效能的行政主管助理，負責協助處理各種工作任務。請用繁體中文回應，簡潔有力，直接提供可執行的建議與行動方案。你擅長：行程規劃、文件撰寫、資料整理、決策分析、任務追蹤。
